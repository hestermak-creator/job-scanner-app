# Not required for local dev (the JSON file store in lib/db.ts needs no env vars).
# Fill these in when you migrate to the real stack — see README > "Migration path".

# Supabase Postgres connection string (for prisma/schema.prisma)
DATABASE_URL=

# Clerk or Supabase Auth keys
NEXT_PUBLIC_AUTH_PUBLISHABLE_KEY=
AUTH_SECRET_KEY=

# Claude API key, for the nightly scan job
ANTHROPIC_API_KEY=

# Trigger.dev / Inngest key, for scheduling the nightly per-user scan
SCHEDULER_API_KEY=

# SMTP or Resend/Postmark key, for sending the email digest
EMAIL_API_KEY=
