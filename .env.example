# Real values for these are already in .env.local (safe to ship — see the
# comment there). This file documents what's needed for the pieces that
# aren't wired up in .env.local yet.

# Public Supabase project (already filled in in .env.local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — Project Settings > API > service_role in the
# Supabase dashboard. Server-only, used exclusively by the nightly scan cron
# job (app/api/cron/scan/route.ts) to read/write every user's rows in one
# batch. NEVER prefix this with NEXT_PUBLIC_ or import lib/supabase/admin.ts
# from anything that runs in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# console.anthropic.com API key, used by the nightly scan to search the web
# and rank matches for each user.
ANTHROPIC_API_KEY=

# Random string (16+ chars) that authenticates Vercel's cron invocations —
# Vercel automatically sends this as a Bearer token when it triggers
# /api/cron/scan, so set the same value here and in Vercel's env vars.
CRON_SECRET=

# SMTP is configured directly in the Supabase dashboard (Authentication >
# Emails > SMTP Settings), not as an app env var — see README.

# Not built yet: sending the daily digest email itself (separate from the
# magic-link auth emails, which SMTP above already handles).
EMAIL_API_KEY=
